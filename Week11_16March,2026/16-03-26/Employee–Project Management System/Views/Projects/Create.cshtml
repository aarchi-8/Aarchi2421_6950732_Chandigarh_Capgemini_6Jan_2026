@model Employee_Project_Management_System.Models.Project

<h2>Create Project</h2>

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label asp-for="Title"></label>
        <input asp-for="Title" class="form-control" />
    </div>

    <h4>Assign Employees</h4>

    @foreach (var e in ViewBag.Employees)
    {
        <div class="form-check">
            <input class="form-check-input" type="checkbox" name="employeeIds" value="@e.EmployeeId" />
            <label class="form-check-label">@e.Name</label>
        </div>
    }

    <br />

    <button type="submit" class="btn btn-primary">Save</button>

</form>