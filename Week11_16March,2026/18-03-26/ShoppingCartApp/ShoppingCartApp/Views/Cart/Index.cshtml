@model List<ShoppingCartApp.Models.CartItem>

<h2>Your Cart</h2>

<table class="table table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Qty</th>
            <th>Total</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @{
            double grandTotal = 0;
        }

        @foreach (var item in Model)
        {
            var total = item.Quantity * item.Product.Price;
            grandTotal += total;

            <tr>
                <td>@item.Product.Name</td>
                <td>₹@item.Product.Price</td>
                <td>@item.Quantity</td>
                <td>₹@total</td>
                <td>
                    <a href="/Cart/Remove/@item.ProductId" class="btn btn-danger btn-sm">Remove</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<h4>Total: ₹@grandTotal</h4>

<a href="/Order/Checkout" class="btn btn-primary">
    Proceed to Checkout
</a>