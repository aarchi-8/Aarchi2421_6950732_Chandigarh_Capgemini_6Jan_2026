@model Product

<div class="container py-5">
    <div class="card shadow border-0">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">Delete Product</h4>
        </div>

        <div class="card-body text-center">
            <p class="fs-5">
                Are you sure you want to delete
                <strong class="text-danger">@Model.Name</strong>?
            </p>

            <form asp-controller="Product" asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="mt-4">
                    <button class="btn btn-danger px-4 me-2">Delete</button>
                    <a href="/Product" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>