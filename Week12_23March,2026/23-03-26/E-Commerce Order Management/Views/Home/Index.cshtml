@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5">

    <!-- Hero Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">🛒 E-Commerce Order Management</h1>
        <p class="lead text-muted">
            Manage Categories, Products, Customers, and Orders efficiently
        </p>
    </div>

    <!-- Cards Section -->
    <div class="row g-4">

        <!-- Category -->
        <div class="col-md-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <h5 class="card-title">📂 Categories</h5>
                    <p class="text-muted">Manage product categories</p>
                    <a href="/Category" class="btn btn-primary btn-sm">View</a>
                </div>
            </div>
        </div>

        <!-- Product -->
        <div class="col-md-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <h5 class="card-title">📦 Products</h5>
                    <p class="text-muted">Add and manage products</p>
                    <a href="/Product" class="btn btn-success btn-sm">View</a>
                </div>
            </div>
        </div>

        <!-- Customer -->
        <div class="col-md-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <h5 class="card-title">👤 Customers</h5>
                    <p class="text-muted">Manage customer details</p>
                    <a href="/Customer" class="btn btn-info btn-sm text-dark">View</a>
                </div>
            </div>
        </div>

        <!-- Orders -->
        <div class="col-md-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <h5 class="card-title">📦 Orders</h5>
                    <p class="text-muted">Track and manage orders</p>
                    <a href="/Order" class="btn btn-dark btn-sm">View</a>
                </div>
            </div>
        </div>

    </div>

    <!-- Footer Note -->
    <div class="text-center mt-5 text-muted">
        <p>Built with ASP.NET Core MVC & Bootstrap</p>
    </div>

</div>