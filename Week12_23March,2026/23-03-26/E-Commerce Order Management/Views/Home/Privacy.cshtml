@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-5">

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <!-- Title -->
            <h2 class="fw-bold mb-3">🔒 Privacy Policy</h2>

            <p class="text-muted">
                Your privacy is important to us. This page explains how we handle your data in our application.
            </p>

            <hr />

            <!-- Section 1 -->
            <h5 class="fw-semibold mt-3">📌 Information Collection</h5>
            <p class="text-muted">
                We collect basic information such as name, email, and order details to provide better services.
            </p>

            <!-- Section 2 -->
            <h5 class="fw-semibold mt-3">🔐 Data Security</h5>
            <p class="text-muted">
                All data is securely stored and protected against unauthorized access using modern security practices.
            </p>

            <!-- Section 3 -->
            <h5 class="fw-semibold mt-3">📊 Usage of Data</h5>
            <p class="text-muted">
                The collected data is used only for managing orders, customers, and improving system performance.
            </p>

            <!-- Section 4 -->
            <h5 class="fw-semibold mt-3">📞 Contact</h5>
            <p class="text-muted">
                If you have any questions regarding this policy, please contact the system administrator.
            </p>

        </div>
    </div>

</div>