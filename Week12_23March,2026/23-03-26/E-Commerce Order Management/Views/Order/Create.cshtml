@model Order

<div class="container mt-5">

    <!-- Card -->
    <div class="card shadow-lg border-0 mx-auto" style="max-width: 700px;">
        <div class="card-body">

            <h3 class="text-center mb-4 fw-bold">🛒 Place Order</h3>

            <form asp-action="Create" method="post">

                <!-- Customer Dropdown -->
                <div class="mb-4">
                    <label class="form-label fw-semibold">Select Customer</label>

                    <select name="CustomerId" class="form-select">
                        <option value="">-- Select Customer --</option>
                        @foreach (var c in ViewBag.Customers)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>

                <!-- Products Section -->
                <div class="mb-4">
                    <label class="form-label fw-semibold">Select Products</label>

                    <div class="border rounded p-3" style="max-height: 200px; overflow-y: auto;">
                        @foreach (var p in ViewBag.Products)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="productIds"
                                       value="@p.Id"
                                       id="product_@p.Id" />

                                <label class="form-check-label" for="product_@p.Id">
                                    @p.Name
                                </label>
                            </div>
                        }
                    </div>
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-between">
                    <a href="/Order" class="btn btn-secondary">
                        ← Back
                    </a>

                    <button type="submit" class="btn btn-success px-4">
                        ✔ Place Order
                    </button>
                </div>

            </form>

        </div>
    </div>

</div>