@page

<style>
body {
    margin: 0;
    height: 100vh;
    background: linear-gradient(135deg, #0f172a, #1e293b);
    display: flex;
    justify-content: center;
    align-items: center;
    color: #f8fafc;
    font-family: 'Segoe UI', sans-serif;
}

/* Glow */
body::before {
    content: "";
    position: absolute;
    width: 500px;
    height: 500px;
    background: #22c55e;
    filter: blur(120px);
    opacity: 0.2;
    top: -100px;
    right: -100px;
}

.register-card {
    width: 400px;
    border-radius: 20px;
    backdrop-filter: blur(20px);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 30px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.4);
    animation: fadeIn 0.6s ease-in-out;
}

@@keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

h1, h2, h3, h4, h5, p, span {
    color: #f8fafc !important;
}

input, select {
    background: rgba(255,255,255,0.08) !important;
    color: #f8fafc !important;
    border: 1px solid rgba(255,255,255,0.15) !important;
    border-radius: 10px;
}

input::placeholder {
    color: #cbd5f5 !important;
}

.btn-register {
    background: linear-gradient(45deg, #22c55e, #16a34a);
    border: none;
    border-radius: 10px;
}

.btn-link {
    color: #cbd5f5;
}

.btn-link:hover {
    color: white;
}
</style>

<div class="register-card">

<h3 class="text-center mb-4">🆕 Create Account</h3>

<input id="username" class="form-control mb-3" placeholder="Username" />
<input id="password" type="password" class="form-control mb-3" placeholder="Password" />

<select id="role" class="form-control mb-4">
    <option value="user">👤 User</option>
    <option value="admin">🛠 Admin</option>
</select>

<button onclick="register()" class="btn btn-register w-100 py-2">
    ✅ Register
</button>

<button onclick="goToLogin()" class="btn btn-link w-100 mt-2">
    Already have account? Login
</button>

</div>

<script>
async function register() {

    // 🔥 FIXED (IMPORTANT)
    const username = document.getElementById("username").value;
    const password = document.getElementById("password").value;
    const role = document.getElementById("role").value;

    if(!username || !password){
        alert("Please fill all fields ❌");
        return;
    }

    const res = await fetch("http://localhost:5003/api/auth/register", {
        method: "POST",
        headers: {"Content-Type":"application/json"},
        body: JSON.stringify({username,password,role})
    });

    if(res.ok){
        alert("Registration Successful ✅");
        window.location.href="/Login";
    } else {
        const err = await res.text();
        alert("Registration Failed ❌: " + err);
    }
}

function goToLogin(){
    window.location.href="/Login";
}
</script>
