<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventBooking</title>

<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />


</head>

<body style="background-color:#f8f9fa;">

@if (Context.Request.Path != "/Login")
{
    <!-- 🔷 NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm px-4">
        <a class="navbar-brand fw-bold fs-4" href="/Home">🎟 EventBooking</a>

        <div class="ms-auto d-flex align-items-center gap-3">

            <!-- 👤 USER INFO -->
            <span id="navUser" class="text-muted small"></span>

            <!-- 🔴 LOGOUT BUTTON -->
            <button onclick="logout()" class="btn btn-outline-danger btn-sm">
                Logout
            </button>

        </div>
    </nav>
}

<!-- 🔷 MAIN CONTENT -->
<div class="container mt-4">
    @RenderBody()
</div>

<!-- 🔷 FOOTER -->
<footer class="text-center mt-5 mb-3 text-muted">
    <small>© 2026 EventBooking</small>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

<script>
    function logout(){
        localStorage.removeItem("token");
        localStorage.removeItem("username");
        localStorage.removeItem("role");

        window.location.href = "/Login";
    }

    function setNavbarUser(){
        let user = localStorage.getItem("username");
        let role = localStorage.getItem("role");

        if(user && document.getElementById("navUser")){
            document.getElementById("navUser").innerText =
                user + " (" + role + ")";
        }
    }

    setNavbarUser();
</script>

@await RenderSectionAsync("Scripts", required: false)


</body>
</html>
