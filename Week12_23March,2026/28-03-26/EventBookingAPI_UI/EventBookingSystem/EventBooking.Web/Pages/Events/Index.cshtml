@page
@model EventBooking.Web.Pages.Events.IndexModel
@{
    ViewData["Title"] = "Events";
}

<!-- HEADER -->
<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
    <div>
        <h2 class="fw-bold mb-1">
            <i class="bi bi-calendar-event text-primary me-2"></i>Upcoming Events
        </h2>
        <p class="text-muted mb-0">Discover and book exciting events near you</p>
    </div>

    <div class="input-group shadow-sm" style="max-width: 280px;">
        <span class="input-group-text bg-white border-end-0">
            <i class="bi bi-search text-muted"></i>
        </span>
        <input type="text" id="searchInput" class="form-control border-start-0"
               placeholder="Search events..." />
    </div>
</div>

<!-- ALERT -->
<div id="alertBox"></div>

<!-- LOADING -->
<div id="loadingSpinner" class="text-center py-5">
    <div class="spinner-border text-primary" role="status"></div>
    <p class="mt-3 text-muted">Fetching events for you...</p>
</div>

<!-- EVENTS GRID -->
<div id="eventsGrid" class="row g-4" style="display:none!important;">
    <!-- JS will inject cards here -->
</div>

<!-- NO RESULTS -->
<div id="noResults" class="text-center py-5 d-none">
    <i class="bi bi-calendar-x display-4 text-muted"></i>
    <p class="mt-3 text-muted fs-5">No events found</p>
</div>

<!-- BOOKING MODAL -->
<div class="modal fade" id="bookingModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">

            <!-- Header -->
            <div class="modal-header bg-dark text-white rounded-top-4">
                <h5 class="modal-title">
                    <i class="bi bi-ticket-perforated me-2"></i>Book Tickets
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body px-4 py-3">

                <div id="modalAlert"></div>

                <div class="mb-3">
                    <label class="fw-semibold text-muted small">EVENT</label>
                    <p id="modalEventTitle" class="fw-bold mb-0"></p>
                </div>

                <div class="mb-3">
                    <label class="fw-semibold text-muted small">DETAILS</label>
                    <p id="modalEventMeta" class="text-muted mb-0"></p>
                </div>

                <div class="mb-3">
                    <label class="fw-semibold">Seats</label>
                    <input type="number" id="seatsInput" class="form-control shadow-sm"
                           min="1" max="100" value="1" />
                    <div class="form-text">
                        Available:
                        <span id="modalAvailable" class="fw-bold text-success"></span>
                    </div>
                    <div class="invalid-feedback" id="seatsError"></div>
                </div>

                <div>
                    <label class="fw-semibold text-muted small">PRICE</label>
                    <p id="modalPrice" class="fw-bold text-primary mb-0"></p>
                </div>

            </div>

            <!-- Footer -->
            <div class="modal-footer border-0 px-4 pb-4">
                <button class="btn btn-light border" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary px-4" id="confirmBookingBtn">
                    <i class="bi bi-check-circle me-1"></i>Confirm
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/events.js" asp-append-version="true"></script>
}