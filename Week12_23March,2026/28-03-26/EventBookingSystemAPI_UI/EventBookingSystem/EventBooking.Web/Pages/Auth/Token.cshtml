@page
@model EventBooking.Web.Pages.Auth.TokenModel
@{
    ViewData["Title"] = "Get Token";
}

<div class="row justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="col-md-8 col-lg-5">

        <div class="card border-0 shadow-lg rounded-4">
      
            <!-- Header -->
            <div class="card-body p-4">

                <div class="text-center mb-4">
                    <i class="bi bi-key-fill text-primary display-6"></i>
                    <h4 class="fw-bold mt-2 mb-1">Generate JWT Token</h4>
                    <p class="text-muted small mb-0">
                        Secure your session to access bookings and events
                    </p>
                </div>

                <!-- ALERT -->
                <div id="alertBox"></div>

                <!-- USER ID -->
                <div class="mb-3">
                    <label for="userId" class="form-label fw-semibold">
                        User ID <span class="text-danger">*</span>
                    </label>
                    <input type="text" id="userId" class="form-control shadow-sm"
                           placeholder="e.g. user-001" value="user-001" />
                    <div class="invalid-feedback" id="userIdErr">
                        User ID is required.
                    </div>
                </div>

                <!-- USER NAME -->
                <div class="mb-4">
                    <label for="userName" class="form-label fw-semibold">
                        Display Name <span class="text-danger">*</span>
                    </label>
                    <input type="text" id="userName" class="form-control shadow-sm"
                           placeholder="e.g. Alice" value="Alice" />
                    <div class="invalid-feedback" id="userNameErr">
                        Display name is required.
                    </div>
                </div>

                <!-- BUTTON -->
                <div class="d-grid">
                    <button id="getTokenBtn" class="btn btn-primary py-2">
                        <i class="bi bi-shield-lock me-1"></i>Generate & Save Token
                    </button>
                </div>

                <!-- TOKEN OUTPUT -->
                <div id="tokenSection" class="mt-4 d-none">

                    <div class="alert alert-success d-flex align-items-center">
                        <i class="bi bi-check-circle me-2"></i>
                        Token successfully saved in session
                    </div>

                    <label class="form-label fw-semibold small">Your Token</label>

                    <div class="bg-light p-3 rounded-3 small text-break border" id="tokenOutput"></div>

                    <div class="d-flex gap-2 mt-3 flex-wrap">
                        <button class="btn btn-outline-secondary btn-sm" id="copyBtn">
                            <i class="bi bi-clipboard me-1"></i>Copy
                        </button>

                        <a asp-page="/Events/Index" class="btn btn-success btn-sm">
                            <i class="bi bi-arrow-right me-1"></i>Go to Events
                        </a>
                    </div>

                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/js/token.js" asp-append-version="true"></script>
}