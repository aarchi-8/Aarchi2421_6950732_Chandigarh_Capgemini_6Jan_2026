@page
@model EventBooking.Web.Pages.Bookings.MyBookingsModel
@{
    ViewData["Title"] = "My Bookings";
}

<!-- HEADER -->
<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
    <div>
        <h2 class="fw-bold mb-1">
            <i class="bi bi-ticket-perforated text-primary me-2"></i>My Bookings
        </h2>
        <p class="text-muted mb-0">Manage and track your event reservations</p>
    </div>

    <a asp-page="/Events/Index" class="btn btn-dark px-3 shadow-sm">
        <i class="bi bi-plus-circle me-1"></i>Book More
    </a>
</div>

<!-- ALERT -->
<div id="alertBox"></div>

<!-- LOADING -->
<div id="loadingSpinner" class="text-center py-5">
    <div class="spinner-border text-primary"></div>
    <p class="mt-3 text-muted">Loading your bookings...</p>
</div>

<!-- BOOKINGS TABLE -->
<div id="bookingsContainer" class="d-none">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <!-- Table -->
        <div class="table-responsive">
            <table class="table align-middle mb-0">

                <!-- Head -->
                <thead class="table-dark">
                    <tr>
                        <th>#ID</th>
                        <th>Event</th>
                        <th>Date</th>
                        <th>Location</th>
                        <th class="text-center">Seats</th>
                        <th>Booked On</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>

                <!-- Body -->
                <tbody id="bookingsTableBody" class="bg-white"></tbody>

            </table>
        </div>
    </div>
</div>

<!-- EMPTY STATE -->
<div id="emptyState" class="text-center py-5 d-none">
    <div class="mb-3">
        <i class="bi bi-ticket-perforated display-4 text-muted"></i>
    </div>
    <h5 class="fw-semibold">No bookings yet</h5>
    <p class="text-muted">Start exploring events and make your first booking</p>
    <a asp-page="/Events/Index" class="btn btn-primary px-4">
        Browse Events
    </a>
</div>

<!-- CANCEL MODAL -->
<div class="modal fade" id="cancelModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">

            <!-- Header -->
            <div class="modal-header bg-danger text-white rounded-top-4">
                <h5 class="modal-title">
                    <i class="bi bi-x-circle me-2"></i>Cancel Booking
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body px-4 py-3">
                <p class="mb-2">
                    Are you sure you want to cancel booking
                    <strong id="cancelBookingId"></strong>?
                </p>
                <p class="text-muted small mb-0">
                    Seats will be released back to the event.
                </p>
            </div>

            <!-- Footer -->
            <div class="modal-footer border-0 px-4 pb-4">
                <button class="btn btn-light border" data-bs-dismiss="modal">
                    Keep It
                </button>
                <button class="btn btn-danger px-3" id="confirmCancelBtn">
                    <i class="bi bi-x-circle me-1"></i>Yes, Cancel
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/bookings.js" asp-append-version="true"></script>
}