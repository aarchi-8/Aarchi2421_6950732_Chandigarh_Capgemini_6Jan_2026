<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — EventHub</title>

    <!-- Bootstrap & Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
            body {
                background: linear-gradient(180deg, #f5f7fb, #eef2ff);
            }

            /* FUN NAVBAR */
            .navbar {
                background: linear-gradient(135deg, #0d6efd, #6f42c1);
                backdrop-filter: blur(12px);
            }

            .navbar-brand {
                letter-spacing: 1px;
                font-size: 1.3rem;
            }

            .nav-link {
                transition: all 0.2s ease;
            }

                .nav-link:hover {
                    background: rgba(255,255,255,0.15);
                    border-radius: 10px;
                }

            .btn-outline-light {
                border-radius: 50px;
            }

            /* MAIN CARD */
            main {
                min-height: 80vh;
            }

            .main-card {
                background: rgba(255,255,255,0.85);
                backdrop-filter: blur(10px);
                border-radius: 20px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            }

            /* FOOTER */
            footer {
                font-size: 14px;
                background: linear-gradient(to right, #ffffff, #f1f5ff);
            }

            /* FUN GLOW EFFECT */
            .glow {
                text-shadow: 0 0 8px rgba(255,255,255,0.8);
            }
    </style>
</head>
<body>

    <!-- 🌟 NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark shadow sticky-top">
        <div class="container">

            <!-- Logo -->
            <a class="navbar-brand fw-bold glow" asp-page="/Index">
                <i class="bi bi-stars me-2 text-warning"></i>EventHub
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Menu -->
            <div class="collapse navbar-collapse" id="navbarNav">

                <!-- Left Links -->
                <ul class="navbar-nav me-auto gap-2">
                    <li class="nav-item">
                        <a class="nav-link px-3" asp-page="/Events/Index">
                            🎉 Events
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link px-3" asp-page="/Bookings/MyBookings">
                            🎟️ My Bookings
                        </a>
                    </li>
                </ul>

                <!-- Right -->
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    <li class="nav-item">
                        <a class="btn btn-light btn-sm px-3 shadow-sm" asp-page="/Auth/Token">
                            🔐 Get Token
                        </a>
                    </li>
                </ul>

            </div>
        </div>
    </nav>

    <!-- 🌈 MAIN CONTENT -->
    <main class="container py-5">
        <div class="main-card p-4">
            @RenderBody()
        </div>
    </main>

    <!-- 🌟 FOOTER -->
    <footer class="border-top mt-auto py-3 shadow-sm">
        <div class="container d-flex justify-content-between align-items-center flex-wrap text-muted small">

            <span>
                ✨ &copy; @DateTime.Now.Year <strong>EventHub</strong>
            </span>

            <span>
                Made with ❤️ for Capgemini 🚀
            </span>

        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>