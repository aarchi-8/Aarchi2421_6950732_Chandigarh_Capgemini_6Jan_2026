@{
    ViewData["Title"] = "SmartCare Health";
}

<div class="dashboard-header">
    <h1>SmartCare Health Management</h1>
    <p>Seamless clinical operations, patient-centered care, and insights in one secure medical platform.</p>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card-custom">
            <div class="card-header-custom">Overview</div>
            <div class="card-body-custom">
                <p>SmartCare is designed for modern medical teams: centralized patient records, appointment workflows, prescription tracking, and clinical analytics.</p>
                <div class="info-grid">
                    <div class="metric-card">
                        <h3>Real-Time Collaboration</h3>
                        <p>Doctors, nurses, and staff coordinate care using a single shared dashboard.</p>
                    </div>
                    <div class="metric-card">
                        <h3>HIPAA-Ready Security</h3>
                        <p>Data encryption, role-based access, and audit logs protect patient privacy.</p>
                    </div>
                    <div class="metric-card">
                        <h3>Insightful Reporting</h3>
                        <p>Performance metrics and appointment trends help you optimize clinic throughput.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card-custom">
            <div class="card-header-custom">Quick Actions</div>
            <div class="card-body-custom">
                <a class="btn btn-primary-custom btn-block-custom" href="/Auth/Login">Login to Dashboard</a>
                <a class="btn btn-outline-primary mt-2 btn-block-custom" href="/Auth/Register">Create Account</a>
                <a class="btn btn-secondary mt-2 btn-block-custom" href="/Home/Privacy">Privacy & Policy</a>
            </div>
        </div>
    </div>
</div>
