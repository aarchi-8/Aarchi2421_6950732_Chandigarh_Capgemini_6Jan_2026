@using SmartHealthCareSystem.Shared.DTOs;
@model List<BillDto>

@{
    ViewData["Title"] = "Manage Bills";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary-blue">Billing Management</h2>
        <a asp-action="CreateBill" class="btn btn-primary" style="background-color: #00a8e8; border: none; font-weight: 600;">
            + Create New Bill
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="alert alert-info" role="alert">
        <strong>Financial Summary:</strong> 
        Total Revenue: <strong style="font-size: 1.2rem; color: #00a8e8;">
            $@(Model?.Sum(b => b.TotalAmount).ToString("0.00") ?? "0.00")
        </strong>
        <span class="ms-3">|</span>
        Paid: <strong style="color: #28a745;">$@(Model?.Where(b => b.PaymentStatus == "Paid").Sum(b => b.TotalAmount).ToString("0.00") ?? "0.00")</strong>
        <span class="ms-3">|</span>
        Pending: <strong style="color: #ffc107;">$@(Model?.Where(b => b.PaymentStatus == "Unpaid").Sum(b => b.TotalAmount).ToString("0.00") ?? "0.00")</strong>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">💵 Billing Records</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Patient</th>
                        <th>Doctor</th>
                        <th>Diagnosis</th>
                        <th>Consultation Fee</th>
                        <th>Medicine Charges</th>
                        <th>Total Amount</th>
                        <th>Payment Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var bill in Model)
                        {
                            var isPaid = bill.PaymentStatus == "Paid";
                            <tr>
                                <td><strong>@(Model.IndexOf(bill) + 1)</strong></td>
                                <td>@bill.PatientName</td>
                                <td>Dr. @bill.DoctorName</td>
                                <td>@(!string.IsNullOrEmpty(bill.Diagnosis) ? bill.Diagnosis : "General care")</td>
                                <td>
                                    <span style="background-color: #e3f2fd; padding: 6px 12px; border-radius: 4px; color: #1976d2; font-weight: 600;">
                                        $@bill.ConsultationFee.ToString("0.00")
                                    </span>
                                </td>
                                <td>
                                    <span style="background-color: #f3e5f5; padding: 6px 12px; border-radius: 4px; color: #7b1fa2; font-weight: 600;">
                                        $@bill.MedicineCharges.ToString("0.00")
                                    </span>
                                </td>
                                <td>
                                    <div style="background: linear-gradient(135deg, #00a8e8 0%, #4fb3d9 100%); color: white; padding: 8px 12px; border-radius: 6px; font-weight: 700; font-size: 1.1rem;">
                                        $@bill.TotalAmount.ToString("0.00")
                                    </div>
                                </td>
                                <td>
                                    <span class="badge" style="padding: 8px 14px; font-weight: 600; font-size: 0.95rem; 
                                        background-color: @(isPaid ? "#28a745" : "#ffc107"); 
                                        color: @(isPaid ? "white" : "#333");">
                                        @(isPaid ? "✓ Paid" : "⏳ Unpaid")
                                    </span>
                                </td>
                                <td>
                                    @if (!isPaid)
                                    {
                                        <button class="btn btn-sm" style="background-color: #00a8e8; color: white; font-weight: 600;">
                                            💳 Collect Payment
                                        </button>
                                    }
                                    else
                                    {
                                        <small style="color: #28a745; font-weight: 600;">✓ Completed</small>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5">
                                <div class="text-muted mb-3">
                                    <i class="bi bi-receipt" style="font-size: 3rem;"></i>
                                    <h4 class="mt-3">No Billing Records Found</h4>
                                    <p>The system has no billing records yet. Create bills for appointments to see them here.</p>
                                </div>
                                <a asp-action="CreateBill" class="btn btn-primary" style="background-color: #00a8e8; border: none; font-weight: 600;">
                                    + Create Your First Bill
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model != null && Model.Count > 0)
        {
            <div class="card-footer">
                <div class="row">
                    <div class="col-md-6">
                        <small class="text-muted">Total Bills: <strong>@Model.Count</strong></small><br/>
                        <small class="text-success">✓ Paid: <strong>@Model.Count(b => b.PaymentStatus == "Paid")</strong></small><br/>
                        <small class="text-warning">⏳ Unpaid: <strong>@Model.Count(b => b.PaymentStatus == "Unpaid")</strong></small>
                    </div>
                    <div class="col-md-6 text-end">
                        <strong style="color: #00a8e8; font-size: 1.1rem;">
                            Total Revenue: $@Model.Sum(b => b.TotalAmount).ToString("0.00")
                        </strong>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
