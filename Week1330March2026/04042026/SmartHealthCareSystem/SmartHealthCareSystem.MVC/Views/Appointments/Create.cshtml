@model SmartHealthCareSystem.Shared.DTOs.CreateAppointmentDto

@{
    ViewData["Title"] = "Book Appointment";
}

<div class="container mt-5" style="max-width: 600px;">
    <div style="margin-bottom: 30px;">
        <h2>Schedule Appointment</h2>
        <p class="text-muted">Select a department and doctor to book your appointment</p>
    </div>

    <form asp-action="Create" method="post" id="appointmentForm">
        <div class="mb-3">
            <label asp-for="PatientId" class="form-label">Patient</label>
            <select asp-for="PatientId" asp-items="ViewBag.Patients" class="form-select" required>
                <option value="">-- Select Patient --</option>
            </select>
            <span asp-validation-for="PatientId" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label for="departmentSelect" class="form-label">Department / Medical Specialty</label>
            <select id="departmentSelect" class="form-select" required>
                <option value="">-- Select Department --</option>
                @foreach (var dept in ViewBag.Departments ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                {
                    <option value="@dept.Value">@dept.Text</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="DoctorId" class="form-label">Doctor</label>
            <select asp-for="DoctorId" class="form-select" id="doctorSelect" required>
                <option value="">-- Select Doctor --</option>
            </select>
            <span asp-validation-for="DoctorId" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="AppointmentDate" class="form-label">Preferred Date & Time</label>
            <input asp-for="AppointmentDate" class="form-control" type="datetime-local" min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
            <span asp-validation-for="AppointmentDate" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Notes" class="form-label">Reason for Visit (Optional)</label>
            <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Describe your symptoms or reason for the visit..."></textarea>
            <span asp-validation-for="Notes" class="text-danger small"></span>
        </div>

        <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">Schedule Appointment</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('departmentSelect').addEventListener('change', async function() {
            const departmentId = this.value;
            const doctorSelect = document.getElementById('doctorSelect');
            
            doctorSelect.innerHTML = '<option value="">-- Loading doctors... --</option>';
            
            if (departmentId) {
                try {
                    const response = await fetch(`/api/doctors/by-department/${departmentId}`);
                    const doctors = await response.json();
                    
                    doctorSelect.innerHTML = '<option value="">-- Select Doctor --</option>';
                    doctors.forEach(doctor => {
                        const option = document.createElement('option');
                        option.value = doctor.doctorId;
                        option.textContent = `${doctor.fullName} - ${doctor.specialization}`;
                        doctorSelect.appendChild(option);
                    });
                } catch (error) {
                    console.error('Error fetching doctors:', error);
                    doctorSelect.innerHTML = '<option value="">Error loading doctors</option>';
                }
            } else {
                doctorSelect.innerHTML = '<option value="">-- Select Doctor --</option>';
            }
        });
    </script>
}
