@model SmartHealthCareSystem.Shared.DTOs.AppointmentDto

@{
    ViewData["Title"] = "Cancel Appointment";
}

<h2 class="text-danger">Cancel Appointment</h2>
<p class="text-muted">Confirm cancellation of the appointment.</p>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title">@Model.DoctorName</h5>
        <p class="mb-1"><strong>Patient:</strong> @Model.PatientName</p>
        <p class="mb-1"><strong>Date:</strong> @Model.AppointmentDate.ToString("g")</p>
        <p class="mb-1"><strong>Status:</strong> @Model.Status</p>
    </div>
</div>

<form asp-action="Delete" asp-route-id="@Model.AppointmentId" method="post">
    <button type="submit" class="btn btn-danger">Cancel Appointment</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Keep Appointment</a>
</form>
