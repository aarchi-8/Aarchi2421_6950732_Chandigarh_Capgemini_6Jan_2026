@model SmartHealthCareSystem.Shared.DTOs.UpdateAppointmentDto

@{
    ViewData["Title"] = "Edit Appointment";
    var appointmentId = ViewBag.AppointmentId as int?;
}

<h2>Edit Appointment</h2>
<p class="text-muted">Update appointment date or status.</p>

<form asp-action="Edit" asp-route-id="@appointmentId" method="post" class="row g-3">
    <div class="col-md-4">
        <label asp-for="PatientId" class="form-label"></label>
        <input asp-for="PatientId" class="form-control" />
        <span asp-validation-for="PatientId" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="DoctorId" class="form-label"></label>
        <select asp-for="DoctorId" asp-items="ViewBag.Doctors" class="form-select"></select>
        <span asp-validation-for="DoctorId" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="AppointmentDate" class="form-label"></label>
        <input asp-for="AppointmentDate" class="form-control" type="datetime-local" />
        <span asp-validation-for="AppointmentDate" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Status" class="form-label"></label>
        <input asp-for="Status" class="form-control" />
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Update Appointment</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
