@model List<SmartHealthCareSystem.Shared.DTOs.AppointmentDto>

@{
    ViewData["Title"] = "Appointments";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2>Appointments</h2>
        <p class="text-muted">Track patient consultations and doctor schedules.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">New Appointment</a>
</div>

<table class="table table-hover table-bordered align-middle">
    <thead class="table-light">
        <tr>
            <th>#</th>
            <th>Patient</th>
            <th>Doctor</th>
            <th>Date</th>
            <th>Status</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted">No appointments found. Add a new appointment or refresh after seeding sample data.</td>
            </tr>
        }
        else
        {
            @foreach (var appointment in Model)
            {
                <tr>
                    <td>@appointment.AppointmentId</td>
                    <td>@appointment.PatientName</td>
                    <td>@appointment.DoctorName</td>
                    <td>@appointment.AppointmentDate.ToString("g")</td>
                    <td>@appointment.Status</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@appointment.AppointmentId" class="btn btn-sm btn-outline-secondary me-2">Edit</a>
                        <a asp-action="Delete" asp-route-id="@appointment.AppointmentId" class="btn btn-sm btn-outline-danger">Cancel</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
