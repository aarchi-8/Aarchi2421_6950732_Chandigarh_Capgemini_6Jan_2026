@using SmartHealthCareSystem.Shared.DTOs;
@model LoginDto

@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg" style="border: none; border-radius: 12px; overflow: hidden;">
                <div style="background: linear-gradient(135deg, #00569e 0%, #00a8e8 100%); padding: 40px; text-align: center; color: white;">
                    <h1 style="font-size: 2.5rem; margin-bottom: 10px; color: #00569e;">SMART</h1>
                    <h2 style="font-size: 1.8rem; margin-bottom: 5px;">Smart Healthcare</h2>
                    <p style="opacity: 0.9; margin: 0;">Login to Your Account</p>
                </div>
                <div class="card-body p-4">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            <div asp-validation-summary="All" class="text-danger"></div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            @ViewBag.ErrorMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Login" asp-controller="Auth" method="post">
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">Email Address</label>
                            <input asp-for="Email" type="email" class="form-control form-control-lg" placeholder="Enter your email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-bold">Password</label>
                            <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="Enter your password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg fw-bold">
                            Sign In
                        </button>
                    </form>

                    <div class="card mt-4 border-light" style="background-color: #f0f8ff;">
                        <div class="card-body">
                            <h6 class="card-title text-primary-blue fw-bold mb-3">Demo Credentials:</h6>
                            <div class="mb-2">
                                <small class="d-block"><strong style="color: #dc3545;">👑 Admin Account</strong></small>
                                <small class="text-muted">Email: admin@hospital.com</small><br>
                                <small class="text-muted">Password: Admin@123</small>
                            </div>
                            <hr style="margin: 10px 0;">
                            <div class="mb-2">
                                <small class="d-block"><strong style="color: #17a2b8;">⚕️ Doctor Account</strong></small>
                                <small class="text-muted">Email: jane.carter@hospital.com</small><br>
                                <small class="text-muted">Password: Doctor@123</small>
                            </div>
                            <hr style="margin: 10px 0;">
                            <div>
                                <small class="d-block"><strong style="color: #28a745;">👤 Patient Account</strong></small>
                                <small class="text-muted">Email: john.patterson@email.com</small><br>
                                <small class="text-muted">Password: Patient@123</small>
                            </div>
                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <p class="text-muted">Don't have an account? 
                            <a asp-action="Register" asp-controller="Auth" class="text-primary-blue fw-bold text-decoration-none">Register here</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}