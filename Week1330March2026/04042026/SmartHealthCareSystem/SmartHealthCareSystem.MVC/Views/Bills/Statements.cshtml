@model List<SmartHealthCareSystem.Shared.DTOs.BillDto>

@{
    ViewData["Title"] = "Billing Statements";
}

<div class="container mt-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Billing Statements</h2>
            <p class="text-muted">View and manage your billing history</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">View All Bills</a>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h6 class="text-muted">Total Bills</h6>
                    <h3 class="text-primary">@ViewBag.TotalBills</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h6 class="text-muted">Total Amount</h6>
                    <h3 class="text-primary">@ViewBag.TotalAmount.ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success bg-opacity-10">
                <div class="card-body text-center">
                    <h6 class="text-success">Paid (@ViewBag.PaidBills)</h6>
                    <h3 class="text-success">@ViewBag.PaidAmount.ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning bg-opacity-10">
                <div class="card-body text-center">
                    <h6 class="text-warning">Unpaid (@ViewBag.UnpaidBills)</h6>
                    <h3 class="text-warning">@ViewBag.UnpaidAmount.ToString("C")</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Filter Statements</h5>
        </div>
        <div class="card-body">
            <form asp-action="Statements" method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-select">
                        <option value="All" selected="@(ViewBag.SelectedStatus == "All" ? "selected" : null)">All Status</option>
                        <option value="Paid" selected="@(ViewBag.SelectedStatus == "Paid" ? "selected" : null)">Paid</option>
                        <option value="Unpaid" selected="@(ViewBag.SelectedStatus == "Unpaid" ? "selected" : null)">Unpaid</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">From Date</label>
                    <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">To Date</label>
                    <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">Apply Filters</button>
                    <a asp-action="Statements" class="btn btn-outline-secondary w-100 mt-2">Clear Filters</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Statements Table -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Billing History</h5>
            @if (Model.Any())
            {
                <button onclick="window.print()" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-printer"></i> Print Statement
                </button>
            }
        </div>
        <div class="table-responsive">
            <table class="table table-hover table-bordered mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Bill #</th>
                        <th>Appointment Date</th>
                        <th>Doctor</th>
                        <th>Department</th>
                        <th>Diagnosis</th>
                        <th class="text-end">Consultation</th>
                        <th class="text-end">Medicine</th>
                        <th class="text-end">Total</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-4">
                                No billing records found for the selected filters.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var bill in Model)
                        {
                            <tr>
                                <td>@bill.BillId</td>
                                <td>@bill.AppointmentDate.ToString("MMM dd, yyyy")</td>
                                <td>@bill.DoctorName</td>
                                <td>@bill.DepartmentName</td>
                                <td>@(!string.IsNullOrEmpty(bill.Diagnosis) ? bill.Diagnosis : "General care")</td>
                                <td class="text-end">@bill.ConsultationFee.ToString("C")</td>
                                <td class="text-end">@bill.MedicineCharges.ToString("C")</td>
                                <td class="text-end fw-bold">@bill.TotalAmount.ToString("C")</td>
                                <td>
                                    <span class="badge @(bill.PaymentStatus == "Paid" ? "bg-success" : "bg-warning")">
                                        @bill.PaymentStatus
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="Receipt" asp-route-id="@bill.BillId" class="btn btn-sm btn-outline-primary">Receipt</a>
                                    @if (bill.PaymentStatus == "Unpaid")
                                    {
                                        <form asp-action="PayBill" asp-route-id="@bill.BillId" method="post" style="display: inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success ms-1">Pay</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <th colspan="7" class="text-end">Statement Total:</th>
                        <th class="text-end">@Model.Sum(b => b.TotalAmount).ToString("C")</th>
                        <th colspan="2"></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <!-- Payment Summary -->
    @if (ViewBag.UnpaidAmount > 0)
    {
        <div class="alert alert-warning mt-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <strong>Outstanding Balance:</strong> @ViewBag.UnpaidAmount.ToString("C") (@ViewBag.UnpaidBills unpaid bills)
                </div>
                <form asp-action="PayBills" asp-controller="Home" method="post">
                    <button type="submit" class="btn btn-success">Pay All Outstanding Bills</button>
                </form>
            </div>
        </div>
    }
    else if (Model.Any())
    {
        <div class="alert alert-success mt-4">
            <i class="bi bi-check-circle"></i> All bills are paid. Thank you for your prompt payments!
        </div>
    }
</div>

@section Scripts {
    <script>
        // Auto-submit form when date filters change
        document.querySelector('input[name="fromDate"]').addEventListener('change', function() {
            if (this.value) {
                // Optional: auto-submit
            }
        });
        document.querySelector('input[name="toDate"]').addEventListener('change', function() {
            if (this.value) {
                // Optional: auto-submit
            }
        });
    </script>
}
