@model SmartHealthCareSystem.Shared.DTOs.DoctorDto

@{
    ViewData["Title"] = "Delete Doctor";
}

<h2 class="text-danger">Delete Doctor</h2>
<p class="text-muted">Confirm deletion for the selected doctor record.</p>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title">@Model.FullName</h5>
        <p class="mb-1"><strong>Specialization:</strong> @Model.Specialization</p>
        <p class="mb-1"><strong>Department:</strong> @Model.DepartmentName</p>
        <p class="mb-1"><strong>Availability:</strong> @Model.Availability</p>
    </div>
</div>

<form asp-action="Delete" asp-route-id="@Model.DoctorId" method="post">
    <button type="submit" class="btn btn-danger">Delete Doctor</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
