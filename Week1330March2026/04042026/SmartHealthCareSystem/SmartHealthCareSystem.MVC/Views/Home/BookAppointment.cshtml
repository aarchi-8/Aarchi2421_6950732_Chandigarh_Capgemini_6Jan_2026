@model SmartHealthCareSystem.Shared.DTOs.CreateAppointmentDto

@{
    ViewData["Title"] = "Book New Appointment";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>✅ @TempData["SuccessMessage"]</strong>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>❌ @TempData["ErrorMessage"]</strong>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header" style="background-color: #f8f9fa; border-bottom: 2px solid #cff0fc;">
                    <h4 class="mb-0 text-primary-blue">
                        📅 Book New Appointment
                    </h4>
                    <small class="text-muted">Schedule an appointment with your preferred doctor</small>
                </div>
                <div class="card-body">
                    <form asp-action="BookAppointment" method="post">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="DoctorId" class="form-label" style="font-weight: 600; color: #00569e;">
                                    👨‍⚕️ Select Doctor
                                </label>
                                <select asp-for="DoctorId" class="form-select" required>
                                    <option value="">Choose a doctor...</option>
                                    @if (ViewBag.Doctors != null)
                                    {
                                        @foreach (var doctor in ViewBag.Doctors)
                                        {
                                            <option value="@doctor.DoctorId">
                                                Dr. @doctor.FullName - @doctor.DepartmentName (@doctor.Specialization)
                                            </option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="DoctorId" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="AppointmentDate" class="form-label" style="font-weight: 600; color: #00569e;">
                                    📆 Appointment Date & Time
                                </label>
                                <input asp-for="AppointmentDate" type="datetime-local" class="form-control" required
                                       min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                                <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                                <small class="form-text text-muted">Please select a date and time in the future</small>
                            </div>
                        </div>

                        <div class="mb-3">
                        <label for="Notes" class="form-label" style="font-weight: 600; color: #00569e;">
                            📝 Reason for Visit
                        </label>
                        <textarea asp-for="Notes" class="form-control" rows="4" placeholder="Describe your reason for booking this appointment"></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="PatientDashboard" class="btn btn-outline-secondary me-md-2">
                                ← Back to Dashboard
                            </a>
                            <button type="submit" class="btn btn-primary" style="background-color: #00a8e8; border: none; font-weight: 600;">
                                📅 Book Appointment
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-format datetime input for better UX
        document.getElementById('AppointmentDate').addEventListener('change', function() {
            const selectedDate = new Date(this.value);
            const now = new Date();

            if (selectedDate < now) {
                alert('Please select a future date and time.');
                this.value = '';
            }
        });
    </script>
}