@using SmartHealthCareSystem.Shared.DTOs;
@model List<AppointmentDto>

@{
    ViewData["Title"] = "Manage Schedule";
}

<div class="container-fluid mt-4">
    <div class="card">
        <div class="card-header bg-light">
            <h4 class="mb-0">Manage Your Schedule</h4>
            <small class="text-muted">See all appointments assigned to you and track upcoming bookings.</small>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Date & Time</th>
                            <th>Patient</th>
                            <th>Status</th>
                            <th>Diagnosis</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            var index = 1;
                            foreach (var appointment in Model)
                            {
                                <tr>
                                    <td><strong>@index</strong></td>
                                    <td>@appointment.AppointmentDate.ToString("dd MMM yyyy HH:mm")</td>
                                    <td>@appointment.PatientName</td>
                                    <td><strong>@appointment.Status</strong></td>
                                    <td>@(!string.IsNullOrWhiteSpace(appointment.Diagnosis) ? appointment.Diagnosis : "No diagnosis yet")</td>
                                </tr>
                                index++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">No schedule data found. You will see appointments here after patients book you.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
