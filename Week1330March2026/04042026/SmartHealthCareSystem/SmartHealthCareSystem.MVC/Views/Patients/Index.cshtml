@model List<SmartHealthCareSystem.Shared.DTOs.PatientDto>
@{
    ViewData["Title"] = "Patients";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2>Patients</h2>
        <p class="text-muted">Patient records and medical history.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Add Patient</a>
</div>
<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" class="form-control" placeholder="Search by name..." value="@Context.Request.Query["search"]" />
        <button class="btn btn-outline-secondary" type="submit">Search</button>
    </div>
</form>
<table class="table table-hover table-bordered align-middle">
    <thead class="table-light">
        <tr>
            <th>#</th>
            <th>Name</th>
            <th>Email</th>
            <th>DOB</th>
            <th>Gender</th>
            <th>Address</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="7" class="text-center text-muted">No patient records available yet.</td>
            </tr>
        }
        else
        {
            @foreach (var patient in Model)
            {
                <tr>
                    <td>@patient.PatientId</td>
                    <td>@patient.FullName</td>
                    <td>@patient.Email</td>
                    <td>@patient.DateOfBirth.ToShortDateString()</td>
                    <td>@patient.Gender</td>
                    <td>@patient.Address</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@patient.PatientId" class="btn btn-sm btn-outline-info me-2">View</a>
                        <a asp-action="Edit" asp-route-id="@patient.PatientId" class="btn btn-sm btn-outline-secondary me-2">Edit</a>
                        <a asp-action="Delete" asp-route-id="@patient.PatientId" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
