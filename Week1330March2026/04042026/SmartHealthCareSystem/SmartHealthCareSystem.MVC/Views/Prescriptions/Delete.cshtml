@model SmartHealthCareSystem.Shared.DTOs.PrescriptionDto

@{
    ViewData["Title"] = "Delete Prescription";
}

<h2 class="text-danger">Delete Prescription</h2>
<p class="text-muted">Confirm the prescription removal.</p>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title">Prescription #@Model.PrescriptionId</h5>
        <p class="mb-1"><strong>Appointment:</strong> @Model.AppointmentId</p>
        <p class="mb-1"><strong>Diagnosis:</strong> @Model.Diagnosis</p>
        <p class="mb-1"><strong>Medicines:</strong> @Model.Medicines</p>
    </div>
</div>

<form asp-action="Delete" asp-route-id="@Model.PrescriptionId" method="post">
    <button type="submit" class="btn btn-danger">Delete Prescription</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
