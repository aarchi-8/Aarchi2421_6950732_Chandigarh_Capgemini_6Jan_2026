<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Health Care</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartHealthCareSystem.MVC.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index" style="font-family: 'Dancing Script', cursive; font-size: 1.5rem;">Smart Health Care</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (Context.Session.GetString("JWTToken") != null)
                        {
                            @if (Context.Session.GetString("UserRole") == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="adminMenu" role="button" data-bs-toggle="dropdown">
                                        Admin
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="adminMenu">
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="ManageUsers">Users</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="ManageDoctors">Doctors</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="ManageAppointments">Appointments</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="ManageDepartments">Departments</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="ManagePrescriptions">Prescriptions</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="ManageBills">Billing</a></li>
                                    </ul>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Doctors" asp-action="Index">Doctors</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Appointments" asp-action="Index">Appointments</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Prescriptions" asp-action="Index">Prescriptions</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Bills" asp-action="Index">Billing</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Departments" asp-action="Index">Departments</a>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                    @if (Context.Session.GetString("JWTToken") != null)
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-light">Logout</button>
                                </form>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-white py-4" style="background: linear-gradient(135deg, var(--primary-blue) 0%, var(--dark-blue) 100%); margin-top: 50px;">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h6 style="color: var(--light-blue);">Smart Healthcare System</h6>
                    <p class="mb-0">&copy; 2026 - Comprehensive Hospital Management Solution</p>
                </div>
                <div class="col-md-6 text-end">
                    <a href="#" class="text-decoration-none me-3" style="color: var(--light-blue);">Privacy</a>
                    <a href="#" class="text-decoration-none" style="color: var(--light-blue);">Terms</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/form-validation.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
